# === Hebrew Voice Assistant — переменные окружения ===
# Скопируй этот файл в .env и заполни значения:
#   cp .env.example .env

# --- Выбор LLM провайдера ---
# "gemini" (по умолчанию) или "anthropic"
LLM_PROVIDER=gemini

# --- Google Gemini ---
GOOGLE_API_KEY=AIzaSy...

# --- Anthropic (Claude API) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- OpenAI (Whisper STT) ---
OPENAI_API_KEY=sk-...

# --- Google Cloud (Text-to-Speech) ---
# Путь к JSON-файлу сервисного аккаунта
GOOGLE_APPLICATION_CREDENTIALS=./credentials/google-tts.json

# --- Home Assistant (Этап 4) ---
HOME_ASSISTANT_URL=http://homeassistant.local:8123
HOME_ASSISTANT_TOKEN=

# --- ElevenLabs (Text-to-Speech) ---
ELEVENLABS_API_KEY=твой_ключ

# --- Narakeet (Text-to-Speech) ---
NARAKEET_API_KEY=твой_ключ

# --- Выбор TTS провайдера ---
# "narakeet" (по умолчанию, Duncan male, иврит) | "openai" | "elevenlabs" | "google"
TTS_PROVIDER=narakeet

# --- Режим колонки (Voice Pipeline) ---
VOICE_PIPELINE_ENABLED=false

# --- Gemini Live API (Этап 5) ---
LIVE_API_ENABLED=false
